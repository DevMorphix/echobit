# All optional — defaults work for the standard same-origin deployment.
# VITE_API_URL=          # override API base (default: same-origin /api)
# VITE_SITE_URL=         # canonical origin for SEO meta (default: https://echobits.xyz)
# VITE_RAZORPAY_KEY_ID=  # Razorpay public key for checkout
# VITE_RAZORPAY_CONFIG_ID=
# VITE_TURNSTILE_SITE_KEY=  # Cloudflare Turnstile sitekey; unset = widget disabled
