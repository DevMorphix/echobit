# Local dev secrets for `wrangler dev` — copy to .dev.vars (gitignored).
# Production values go in via `wrangler secret put <NAME>`.
JWT_SECRET=change-me                  # MUST match the old backend's secret in prod (keeps mobile sessions alive)
SARVAM_API_KEY=
GEMINI_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_MOCK=true
GOOGLE_CLIENT_ID=1004219063159-uhcjuruvg9fp6c0ti5rad22gi64am8k4.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=                  # only needed for Better Auth Google sign-in
# Better Auth (web). Secret: openssl rand -base64 32. URL: localhost in dev.
BETTER_AUTH_SECRET=dev-better-auth-secret-change-me
BETTER_AUTH_URL=http://localhost:5173
TURNSTILE_SECRET=                     # Turnstile secret; unset = bot check skipped (web-origin only when set)
# R2 S3 credentials — ONLY needed for presigned upload URLs + signed audio URLs
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# AI Gateway (optional) — leave unset to call providers directly
#AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/<account_id>/echobit
#AI_GATEWAY_ID=echobit
# VM meeting bot (Google Meet recorder). URL is also a wrangler.jsonc var; the
# bearer secret must match the bot VM's .env MEET_BOT_SECRET. Unset = bot disabled.
MEET_BOT_URL=http://localhost:8080
MEET_BOT_SECRET=
# Bypass Cloudflare Access on the admin routes locally (Access only runs at the
# edge, never in front of `wrangler dev`). Overrides ENVIRONMENT=production from
# wrangler.jsonc. Never set this to "development" in production.
ENVIRONMENT=development
