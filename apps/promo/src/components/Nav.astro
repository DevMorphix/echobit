---
// Shared light top nav. App links (Sign in / Get started) deep-link to the Vue
// app, which is served on the same origin by the Worker.
const links = [
  { href: '/#features', label: 'Features' },
  { href: '/#languages', label: 'Languages' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/80 backdrop-blur-md">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 font-bold text-slate-900">
      <img src="/favicon.png" alt="Echobit" class="w-8 h-8 rounded-lg object-contain" />
      <span class="text-lg tracking-tight">Echobit</span>
    </a>

    <div class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-600">
      {links.map((l) => (
        <a href={l.href} class="hover:text-slate-900 transition-colors">{l.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-2 sm:gap-3">
      <a href="/login" class="text-sm font-medium text-slate-600 hover:text-slate-900 px-3 py-2 transition-colors">Sign in</a>
      <a href="/register" class="text-sm font-semibold bg-emerald-600 hover:bg-emerald-500 text-white px-4 py-2 rounded-full shadow-sm shadow-emerald-600/20 transition-colors">
        Get started
      </a>
    </div>
  </nav>
</header>
