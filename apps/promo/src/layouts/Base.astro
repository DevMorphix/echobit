---
import '@fontsource-variable/inter';
import '@fontsource-variable/sora';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  path?: string;        // route path for canonical/og:url, e.g. '/pricing'
  ogImage?: string;
  chrome?: boolean;     // render the shared Nav + Footer (default true)
  jsonLd?: object[];    // page-specific structured data (FAQ, Breadcrumb, …)
}

const {
  title = 'Echobit – AI Meeting Recorder & Transcriber',
  description = 'Record, transcribe and summarize meetings with AI. Supports 20+ Indian languages including Hindi, Malayalam, Tamil & Telugu. Free plan available.',
  path = '/',
  ogImage = '/og-image.png',
  chrome = true,
  jsonLd = [],
} = Astro.props;

const canonical = new URL(path, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
const siteUrl = Astro.site!.href.replace(/\/$/, '');

// Site-wide structured data (every page).
const baseSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Devmorphix',
    url: siteUrl,
    logo: `${siteUrl}/favicon.png`,
    brand: { '@type': 'Brand', name: 'Echobit' },
    sameAs: [],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Echobit',
    url: siteUrl,
    description: 'AI-powered meeting recorder and transcriber supporting 20+ Indian languages.',
    publisher: { '@type': 'Organization', name: 'Devmorphix' },
  },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="AI meeting recorder, meeting transcription, voice to text, meeting notes, AI summary, meeting minutes, audio transcription, Hindi transcription, Malayalam transcription, Tamil transcription, Indian language AI, lecture transcription" />
    <meta name="author" content="Devmorphix" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="application-name" content="Echobit" />
    <meta name="apple-mobile-web-app-title" content="Echobit" />
    <meta name="theme-color" content="#ffffff" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Echobit" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1731" />
    <meta property="og:image:height" content="909" />
    <meta property="og:image:alt" content="Echobit — AI meeting recorder & transcriber" />
    <meta property="og:locale" content="en_IN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {baseSchema.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Mark JS-capable before paint so reveal styles only hide for JS users -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    <slot name="head" />
  </head>
  <body class="bg-white text-slate-900 antialiased">
    {chrome && <Nav />}
    <main>
      <slot />
    </main>
    {chrome && <Footer />}

    <script>
      // Subtle scroll-reveal (progressive enhancement).
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window && els.length) {
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          }
        }, { threshold: 0.12 });
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('in'));
      }
    </script>
  </body>
</html>
