---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found – Echobit" description="The page you're looking for doesn't exist." path="/404">
  <section class="max-w-xl mx-auto px-6 py-28 text-center">
    <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">404</p>
    <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight text-slate-900">Page not found</h1>
    <p class="mt-4 text-slate-600">The page you're looking for doesn't exist or has moved.</p>
    <a href="/" class="mt-8 inline-flex items-center gap-2 rounded-full bg-emerald-600 px-6 py-3 font-semibold text-white hover:bg-emerald-500 transition-colors">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12" /></svg>
      Back to home
    </a>
  </section>
</Base>
