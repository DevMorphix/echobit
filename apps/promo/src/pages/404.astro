---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found – Echobit" description="The page you're looking for doesn't exist." path="/404">
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-black via-gray-900 to-emerald-950 text-white px-6 text-center">
    <div>
      <p class="text-emerald-400 text-sm font-semibold uppercase tracking-widest mb-3">404</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">Page not found</h1>
      <p class="text-white/60 mb-8">The page you're looking for doesn't exist or has moved.</p>
      <a href="/" class="inline-flex items-center gap-2 bg-emerald-500 hover:bg-emerald-400 text-white px-6 py-3 rounded-full font-semibold transition">Back to home</a>
    </div>
  </div>
</Base>
