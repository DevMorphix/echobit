---
import Base from '../layouts/Base.astro';
import { DEFAULT_PRICES, DEFAULT_FEATURES } from '@echobit/shared/plans';

// Static marketing teaser. Real checkout (Razorpay) lives in the app — these
// CTAs send visitors to sign up, then upgrade inside the dashboard.
const tiers = [
  { key: 'free',    name: 'Free',    tagline: 'For getting started', highlighted: false, cta: 'Get started' },
  { key: 'starter', name: 'Starter', tagline: 'For light use',       highlighted: false, cta: 'Choose Starter' },
  { key: 'pro',     name: 'Pro',     tagline: 'For power users',      highlighted: true,  cta: 'Choose Pro' },
  { key: 'growth',  name: 'Growth',  tagline: 'For teams',           highlighted: false, cta: 'Choose Growth' },
] as const;

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Echobit',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Android, Web',
    description: 'AI meeting recorder and transcriber with transcription in 20+ Indian languages, summaries, and meeting minutes.',
    offers: tiers.map((t) => ({
      '@type': 'Offer',
      name: `Echobit ${t.name}`,
      price: String(DEFAULT_PRICES[t.key].monthlyPaise / 100),
      priceCurrency: 'INR',
      category: 'monthly subscription',
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://echobits.xyz/' },
      { '@type': 'ListItem', position: 2, name: 'Pricing', item: 'https://echobits.xyz/pricing' },
    ],
  },
];
---
<Base
  title="Pricing – Echobit"
  description="Simple, transparent pricing for Echobit. Start free, upgrade when you need more. Pro plans from ₹499/month, billed monthly or annually."
  path="/pricing"
  jsonLd={pageSchema}
>
  <section class="relative overflow-hidden max-w-6xl mx-auto px-6 pt-20 pb-24">
    <div class="pointer-events-none absolute left-1/2 top-[-6rem] -z-10 h-72 w-[40rem] -translate-x-1/2 rounded-full bg-emerald-500/20 blur-3xl animate-float-slow"></div>
    <div class="text-center max-w-2xl mx-auto mb-14">
      <p class="text-sm font-semibold uppercase tracking-wider text-emerald-400">Pricing</p>
      <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight text-white">Start free. Upgrade when you grow.</h1>
      <p class="mt-4 text-lg text-slate-300">No credit card to start. Cancel anytime. Save with annual billing.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch reveal">
      {tiers.map((tier) => (
        <div data-stagger class="relative h-full">
          {tier.highlighted && (
            <span class="absolute -top-3 left-1/2 z-10 -translate-x-1/2 whitespace-nowrap rounded-full bg-emerald-500 px-3 py-1 text-xs font-bold text-[#05080a] shadow-lg shadow-emerald-500/30">Most popular</span>
          )}
          <div class={`flex h-full flex-col rounded-2xl p-7 ${tier.highlighted ? 'card-featured' : 'card'}`}>
            <h2 class="text-lg font-semibold text-white">{tier.name}</h2>
            <p class="mt-1 text-sm text-slate-400">{tier.tagline}</p>
            <p class="mt-4 text-4xl font-bold text-white">
              {DEFAULT_PRICES[tier.key].monthlyPrice}<span class="text-base font-normal text-slate-400">/mo</span>
            </p>
            <p class="mt-1 text-xs text-emerald-400 font-medium">{DEFAULT_PRICES[tier.key].annualMonthly}/mo billed annually</p>
            <ul class="mt-6 space-y-2.5 flex-1">
              {DEFAULT_FEATURES[tier.key].map((f) => (
                <li class={`flex items-start gap-2.5 text-sm ${f.included ? 'text-slate-300' : 'text-slate-600'}`}>
                  {f.included ? (
                    <svg class="h-4 w-4 flex-shrink-0 mt-0.5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                  ) : (
                    <svg class="h-4 w-4 flex-shrink-0 mt-0.5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                  )}
                  {f.text}
                </li>
              ))}
            </ul>
            <a
              href="/register"
              class={`mt-7 block rounded-xl py-3 text-center text-sm font-semibold transition-colors ${tier.highlighted ? 'btn-primary bg-emerald-500 text-[#05080a] hover:bg-emerald-400' : 'border border-white/15 bg-white/5 text-slate-200 hover:bg-white/10'}`}
            >
              {tier.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

    <p class="mt-10 text-center text-sm text-slate-400">
      All plans include AI transcription &amp; summaries. Paid plans unlock more recordings, languages, and exports.
      Questions? <a href="/contact" class="font-medium text-emerald-400 underline hover:text-emerald-300">Talk to us</a>.
    </p>
  </section>
</Base>
