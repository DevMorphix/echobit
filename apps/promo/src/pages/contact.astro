---
import Base from '../layouts/Base.astro';

const subjects = ['General Inquiry', 'Technical Support', 'Account & Data', 'Privacy & Deletion', 'Feature Request', 'Bug Report', 'Other'];
const inputCls = 'w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition';
---
<Base
  title="Contact Us – Echobit"
  description="Get in touch with the Echobit team. We are here to help with any questions about our AI meeting recorder."
  path="/contact"
>
  <section class="max-w-5xl mx-auto px-6 py-16 sm:py-20">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">Get in touch</p>
      <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight text-slate-900">Contact us</h1>
      <p class="mt-4 text-lg text-slate-600">Have a question, feedback, or need a hand with Echobit? We usually reply within 24 hours.</p>
    </div>

    <div class="mt-12 grid lg:grid-cols-5 gap-8">
      <!-- Form -->
      <div class="lg:col-span-3 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
        <div id="success" class="hidden text-center py-10">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-emerald-50 text-emerald-600">
            <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          </div>
          <h2 class="mt-4 text-lg font-semibold text-slate-900">Opening your email…</h2>
          <p class="mt-1 text-sm text-slate-500">If nothing opened, write to us at <a href="mailto:no.reply.echobit@gmail.com" class="font-medium text-emerald-600 underline">no.reply.echobit@gmail.com</a>.</p>
        </div>

        <form id="contact-form" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">Your name</label>
            <input id="name" name="name" type="text" required placeholder="John Doe" class={inputCls} />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">Email address</label>
            <input id="email" name="email" type="email" required placeholder="you@example.com" class={inputCls} />
          </div>
          <div>
            <label for="subject" class="block text-sm font-medium text-slate-700 mb-1.5">Subject</label>
            <select id="subject" name="subject" required class={inputCls}>
              <option value="" disabled selected>Select a topic…</option>
              {subjects.map((s) => <option value={s}>{s}</option>)}
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-slate-700 mb-1.5">Message</label>
            <textarea id="message" name="message" required rows="5" placeholder="Tell us what's on your mind…" class={inputCls}></textarea>
          </div>
          <button type="submit" class="w-full rounded-full bg-emerald-600 py-3 font-semibold text-white shadow-sm shadow-emerald-600/20 hover:bg-emerald-500 transition-colors">
            Send message
          </button>
        </form>
      </div>

      <!-- Info -->
      <div class="lg:col-span-2 space-y-4">
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="mt-4 font-semibold text-slate-900">Email support</h3>
          <p class="mt-1 text-sm text-slate-500">We typically respond within 24 hours.</p>
          <a href="mailto:no.reply.echobit@gmail.com" class="mt-2 inline-block text-sm font-medium text-emerald-600 underline hover:text-emerald-700">no.reply.echobit@gmail.com</a>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="font-semibold text-slate-900">Account &amp; data deletion</h3>
          <p class="mt-1 text-sm text-slate-500">Want to delete your account and all data?</p>
          <a href="/request-deletion" class="mt-2 inline-block text-sm font-medium text-emerald-600 underline hover:text-emerald-700">Submit a deletion request →</a>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="font-semibold text-slate-900">Privacy</h3>
          <p class="mt-1 text-sm text-slate-500">Learn how we handle your data.</p>
          <a href="/privacy-policy" class="mt-2 inline-block text-sm font-medium text-emerald-600 underline hover:text-emerald-700">Read our Privacy Policy →</a>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const success = document.getElementById('success');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name = String(data.get('name') ?? '');
      const email = String(data.get('email') ?? '');
      const subject = String(data.get('subject') ?? '');
      const message = String(data.get('message') ?? '');
      const body = encodeURIComponent(`Name: ${name}\nEmail: ${email}\nSubject: ${subject}\n\n${message}`);
      const href = `mailto:no.reply.echobit@gmail.com?subject=${encodeURIComponent('[Echobit] ' + subject)}&body=${body}`;
      form.classList.add('hidden');
      success?.classList.remove('hidden');
      window.location.href = href;
    });
  </script>
</Base>
