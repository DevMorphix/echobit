---
import Base from '../layouts/Base.astro';

const subjects = ['General Inquiry', 'Technical Support', 'Account & Data', 'Privacy & Deletion', 'Feature Request', 'Bug Report', 'Other'];
const inputCls = 'field';
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '0x4AAAAAADlDPjPGRxOUKni0';

const channels = [
  {
    title: 'Email us directly',
    desc: 'support@echobits.xyz',
    href: 'mailto:support@echobits.xyz',
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
  {
    title: 'Account & data deletion',
    desc: 'Submit a deletion request →',
    href: '/request-deletion',
    icon: 'M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16',
  },
  {
    title: 'Privacy',
    desc: 'Read our Privacy Policy →',
    href: '/privacy-policy',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
];
---
<Base
  title="Contact – Echobit"
  description="Get in touch with the Echobit team. We are here to help with any questions about our AI meeting recorder."
  path="/contact"
>
  <section class="lg:grid lg:grid-cols-2 lg:min-h-[calc(100vh-4rem)]">
    <!-- Left: brand + channels -->
    <div class="relative overflow-hidden flex items-center border-b border-white/10 bg-gradient-to-br from-emerald-600/15 via-[#070d0c] to-teal-600/10 px-6 py-16 sm:py-20 lg:border-b-0 lg:border-r lg:px-14">
      <div class="pointer-events-none absolute -top-24 -left-16 h-72 w-72 rounded-full bg-emerald-500/20 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-24 right-0 h-72 w-72 rounded-full bg-teal-500/10 blur-3xl"></div>
      <div class="relative max-w-md">
        <a href="/" class="inline-flex items-center gap-2.5 font-bold text-white">
          <img src="/favicon.png" alt="Echobit" width="32" height="32" class="w-8 h-8 rounded-lg object-contain" />
          <span class="text-lg tracking-tight">Echobit</span>
        </a>
        <h1 class="mt-12 text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
          Let’s <span class="text-gradient">talk.</span>
        </h1>
        <p class="mt-6 text-lg text-slate-300 leading-relaxed">
          Questions, feedback, or a bug to report? Send us a note and we’ll get back to you —
          usually within 24 hours.
        </p>

        <ul class="mt-10 space-y-3">
          {channels.map((c) => (
            <li>
              <a href={c.href} class="group flex items-center gap-4 rounded-2xl border border-white/10 bg-white/[0.03] p-4 transition-colors hover:border-emerald-400/30 hover:bg-white/[0.06]">
                <span class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400 ring-1 ring-inset ring-emerald-400/20">
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={c.icon} /></svg>
                </span>
                <span>
                  <span class="block text-sm font-semibold text-white">{c.title}</span>
                  <span class="block text-sm text-slate-400 transition-colors group-hover:text-emerald-300">{c.desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Right: the form -->
    <div class="flex items-center px-6 py-16 sm:py-20 lg:px-14">
      <div class="w-full max-w-md mx-auto">
        <!-- Success state -->
        <div id="success" class="hidden rounded-3xl border border-emerald-400/30 bg-emerald-500/[0.07] p-8 text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-emerald-500/15 text-emerald-400 ring-1 ring-inset ring-emerald-400/30">
            <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          </div>
          <h2 class="mt-4 text-xl font-bold text-white">Message sent</h2>
          <p class="mt-2 text-sm text-slate-300 leading-relaxed">Thanks for reaching out — we’ll reply by email, usually within 24 hours. You can also write to us at <a href="mailto:support@echobits.xyz" class="font-medium text-emerald-400 underline hover:text-emerald-300">support@echobits.xyz</a>.</p>
        </div>

        <!-- Form -->
        <div id="form-card">
          <p class="text-sm font-semibold uppercase tracking-wider text-emerald-400">Send a message</p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight text-white">Get in touch</h2>
          <p class="mt-2 text-sm text-slate-400">Fill in the form and we’ll reply by email.</p>

          <form id="contact-form" class="mt-7 space-y-4">
            <div>
              <label for="name" class="block text-sm font-medium text-slate-300 mb-1.5">Your name</label>
              <input id="name" name="name" type="text" required placeholder="John Doe" class={inputCls} />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-slate-300 mb-1.5">Email address</label>
              <input id="email" name="email" type="email" required placeholder="you@example.com" class={inputCls} />
            </div>
            <div>
              <label for="subject-btn" class="block text-sm font-medium text-slate-300 mb-1.5">Subject</label>
              <div class="relative">
                <button type="button" id="subject-btn" aria-haspopup="listbox" aria-expanded="false" aria-controls="subject-menu"
                  class="field flex w-full items-center justify-between gap-2 text-left">
                  <span id="subject-display" class="text-slate-500">Select a topic…</span>
                  <svg id="subject-chevron" class="h-4 w-4 flex-shrink-0 text-slate-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </button>
                <input type="hidden" id="subject" name="subject" value="" />
                <ul id="subject-menu" role="listbox" aria-label="Subject" tabindex="-1"
                  class="hidden absolute left-0 right-0 z-20 mt-2 max-h-60 overflow-auto rounded-xl border border-white/10 bg-[#0a1512] p-1 shadow-2xl shadow-black/50">
                  {subjects.map((s) => (
                    <li role="option" data-value={s}
                      class="flex cursor-pointer items-center justify-between gap-2 rounded-lg px-3 py-2.5 text-sm text-slate-200 transition-colors hover:bg-white/5">
                      <span>{s}</span>
                      <svg class="check h-4 w-4 flex-shrink-0 text-emerald-400 opacity-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-slate-300 mb-1.5">Message</label>
              <textarea id="message" name="message" required rows="5" placeholder="Tell us what’s on your mind…" class={inputCls}></textarea>
            </div>
            {TURNSTILE_SITE_KEY && <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="dark" data-size="flexible"></div>}
            <p id="error" class="hidden rounded-lg bg-red-500/10 border border-red-400/30 px-4 py-2.5 text-sm text-red-300"></p>
            <button type="submit" class="btn-primary w-full rounded-full bg-emerald-500 py-3.5 font-semibold text-[#05080a] hover:bg-emerald-400 transition-colors">
              Send message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  {TURNSTILE_SITE_KEY && <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const success = document.getElementById('success');
    const formCard = document.getElementById('form-card');
    const errEl = document.getElementById('error');

    // Custom dropdown (no native <select>) for the subject.
    const ddBtn = document.getElementById('subject-btn');
    const ddMenu = document.getElementById('subject-menu');
    const ddInput = document.getElementById('subject') as HTMLInputElement | null;
    const ddDisplay = document.getElementById('subject-display');
    const ddChevron = document.getElementById('subject-chevron');
    const ddOptions = ddMenu ? Array.from(ddMenu.querySelectorAll<HTMLLIElement>('[role="option"]')) : [];
    let ddActive = -1;

    const ddIsOpen = () => !!ddMenu && !ddMenu.classList.contains('hidden');
    const ddHighlight = () => {
      ddOptions.forEach((o, i) => o.classList.toggle('bg-white/5', i === ddActive));
      if (ddActive >= 0) ddOptions[ddActive]?.scrollIntoView({ block: 'nearest' });
    };
    const ddOpen = () => {
      if (!ddMenu) return;
      ddMenu.classList.remove('hidden');
      ddBtn?.setAttribute('aria-expanded', 'true');
      ddChevron?.classList.add('rotate-180');
      ddActive = ddOptions.findIndex((o) => o.getAttribute('aria-selected') === 'true');
      if (ddActive < 0) ddActive = 0;
      ddHighlight();
    };
    const ddClose = () => {
      if (!ddMenu) return;
      ddMenu.classList.add('hidden');
      ddBtn?.setAttribute('aria-expanded', 'false');
      ddChevron?.classList.remove('rotate-180');
      ddActive = -1;
    };
    const ddChoose = (opt: HTMLElement) => {
      const val = opt.getAttribute('data-value') ?? '';
      if (ddInput) ddInput.value = val;
      if (ddDisplay) { ddDisplay.textContent = val; ddDisplay.classList.remove('text-slate-500'); ddDisplay.classList.add('text-white'); }
      ddOptions.forEach((o) => {
        const sel = o === opt;
        o.setAttribute('aria-selected', String(sel));
        o.querySelector('.check')?.classList.toggle('opacity-0', !sel);
      });
      ddClose();
      ddBtn?.focus();
    };

    ddBtn?.addEventListener('click', () => (ddIsOpen() ? ddClose() : ddOpen()));
    ddOptions.forEach((o) => o.addEventListener('click', () => ddChoose(o)));
    ddBtn?.addEventListener('keydown', (e) => {
      switch (e.key) {
        case 'ArrowDown':
          e.preventDefault();
          if (!ddIsOpen()) ddOpen();
          else { ddActive = Math.min(ddActive + 1, ddOptions.length - 1); ddHighlight(); }
          break;
        case 'ArrowUp':
          e.preventDefault();
          if (ddIsOpen()) { ddActive = Math.max(ddActive - 1, 0); ddHighlight(); }
          break;
        case 'Enter':
        case ' ':
          e.preventDefault();
          if (!ddIsOpen()) ddOpen();
          else if (ddActive >= 0) ddChoose(ddOptions[ddActive]);
          break;
        case 'Escape':
          if (ddIsOpen()) { e.preventDefault(); ddClose(); }
          break;
      }
    });
    document.addEventListener('click', (e) => {
      if (ddIsOpen() && !ddMenu!.contains(e.target as Node) && !ddBtn!.contains(e.target as Node)) ddClose();
    });

    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name = String(data.get('name') ?? '');
      const email = String(data.get('email') ?? '');
      const subject = String(data.get('subject') ?? '');
      const message = String(data.get('message') ?? '');
      // Subject is a custom dropdown (hidden input), so validate it here.
      if (!subject) {
        if (errEl) { errEl.textContent = 'Please select a subject.'; errEl.classList.remove('hidden'); }
        ddBtn?.focus();
        return;
      }
      const turnstileToken = (document.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement | null)?.value ?? '';
      if (document.querySelector('.cf-turnstile') && !turnstileToken) {
        if (errEl) { errEl.textContent = 'Please complete the verification below.'; errEl.classList.remove('hidden'); }
        return;
      }
      errEl?.classList.add('hidden');
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending…'; }
      try {
        const res = await fetch('/api/v1/auth/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, subject, message, turnstileToken }),
        });
        const resBody = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(resBody.error || 'Failed to send message');
        formCard?.classList.add('hidden');
        success?.classList.remove('hidden');
        success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } catch (err) {
        if (errEl) { errEl.textContent = (err as Error).message; errEl.classList.remove('hidden'); }
        (window as unknown as { turnstile?: { reset(): void } }).turnstile?.reset();
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send message'; }
      }
    });
  </script>
</Base>
