---
import Base from '../layouts/Base.astro';

const blocks = [
  {
    eyebrow: 'Capture',
    title: 'Record anywhere — even in the background',
    body: 'Start a recording from the web or the Android app and keep working. Echobit records in the background so you stay present in the conversation, then processes everything automatically when you stop.',
    points: ['Web + Android recording', 'Background capture on Android', 'Up to 3-hour sessions', 'Cloud Sync across devices'],
    d: 'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z',
  },
  {
    eyebrow: 'Transcribe',
    title: 'Accurate transcription in 20+ Indian languages',
    body: 'Most tools stop at English. Echobit transcribes English and 20+ Indian languages with native-level accuracy, handling accents, code-switching, crosstalk, and background noise.',
    points: ['Hindi, Tamil, Telugu, Malayalam & more', 'Handles accents & code-switching', 'Auto language detection', 'Clean, readable formatting'],
    d: 'M3 5h12M9 3v2m1.048 3.5A18.022 18.022 0 016.412 9m6.088 9L21 21m-3-3a18.022 18.022 0 01-3.588-9M3 21l3-3',
  },
  {
    eyebrow: 'Summarise',
    title: 'AI summaries the moment you stop recording',
    body: 'Echobit distills long conversations into a concise, readable summary with the key points and decisions — so you never re-listen to an hour-long meeting again.',
    points: ['One-tap AI summary', 'Key points & decisions', 'Summaries in your language', 'Searchable transcripts'],
    d: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  },
  {
    eyebrow: 'Organise',
    title: 'Action items & professional meeting minutes',
    body: 'Echobit pulls out tasks, owners, and deadlines, and assembles polished meeting minutes you can share — exportable as PDF with built-in or custom templates.',
    points: ['Automatic action-item extraction', 'Attendees, decisions, next steps', 'PDF export', 'Custom minute templates'],
    d: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
  },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://echobits.xyz/' },
    { '@type': 'ListItem', position: 2, name: 'Features', item: 'https://echobits.xyz/features' },
  ],
};
---
<Base
  title="Features – Echobit"
  description="Explore Echobit's features: background recording, transcription in 20+ Indian languages, AI summaries, action items, and PDF meeting minutes."
  path="/features"
  jsonLd={[breadcrumb]}
>
  <!-- Header -->
  <section class="relative overflow-hidden max-w-4xl mx-auto px-6 pt-20 pb-10 text-center">
    <div class="pointer-events-none absolute left-1/2 top-[-6rem] -z-10 h-72 w-[36rem] -translate-x-1/2 rounded-full bg-emerald-500/20 blur-3xl animate-float-slow"></div>
    <p class="text-sm font-semibold uppercase tracking-wider text-emerald-400">Features</p>
    <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight text-white leading-tight">Everything Echobit does, in detail</h1>
    <p class="mt-5 text-lg text-slate-300 max-w-2xl mx-auto">From the moment you hit record to the polished minutes you share — here's how Echobit turns conversations into clarity.</p>
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href="/register" class="btn-primary w-full sm:w-auto rounded-full bg-emerald-500 px-7 py-3.5 font-semibold text-[#05080a] hover:bg-emerald-400 transition-colors">Start for free</a>
      <a href="/pricing" class="w-full sm:w-auto rounded-full border border-white/15 bg-white/5 px-7 py-3.5 font-semibold text-slate-200 backdrop-blur-sm hover:border-white/30 hover:bg-white/10 transition-colors">See pricing</a>
    </div>
  </section>

  <!-- Feature blocks -->
  <section class="max-w-5xl mx-auto px-6 py-10 space-y-6">
    {blocks.map((b, i) => (
      <div class="reveal card grid md:grid-cols-2 gap-8 items-center rounded-3xl p-8 sm:p-10">
        <div class={i % 2 === 0 ? '' : 'md:order-2'}>
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400 ring-1 ring-inset ring-emerald-400/20">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={b.d} /></svg>
          </div>
          <p class="mt-5 text-xs font-semibold uppercase tracking-wider text-emerald-400">{b.eyebrow}</p>
          <h2 class="mt-2 text-2xl font-bold tracking-tight text-white">{b.title}</h2>
          <p class="mt-3 text-slate-300 leading-relaxed">{b.body}</p>
        </div>
        <ul class={`space-y-3 ${i % 2 === 0 ? '' : 'md:order-1'}`}>
          {b.points.map((p) => (
            <li class="flex items-center gap-3 rounded-xl bg-white/[0.03] border border-white/10 px-4 py-3 text-sm text-slate-200 transition-colors hover:border-emerald-400/30 hover:bg-emerald-500/5">
              <svg class="h-4 w-4 flex-shrink-0 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
              {p}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>

  <!-- Languages callout -->
  <section class="max-w-5xl mx-auto px-6 py-16 text-center reveal">
    <h2 class="text-3xl font-bold tracking-tight text-white">Built for India's languages</h2>
    <p class="mt-3 text-slate-300 max-w-xl mx-auto">Speak naturally — Echobit understands 20+ Indian languages and still gives you English-ready summaries.</p>
    <div class="mt-6 flex flex-wrap justify-center gap-2">
      {['Hindi','Tamil','Telugu','Bengali','Kannada','Malayalam','Marathi','Gujarati','Punjabi','Odia','English'].map((l) => (
        <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-sm text-slate-300 backdrop-blur-sm transition-colors hover:border-emerald-400/40 hover:text-white">{l}</span>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 pb-24">
    <div class="relative overflow-hidden rounded-3xl border border-emerald-400/20 bg-gradient-to-br from-emerald-500/10 via-white/[0.02] to-teal-500/10 px-8 py-14 text-center">
      <div class="pointer-events-none absolute -right-24 -top-24 h-64 w-64 rounded-full bg-emerald-500/30 blur-3xl animate-float"></div>
      <div class="relative">
        <h2 class="text-3xl font-bold tracking-tight text-white">Try every feature free</h2>
        <p class="mt-3 text-slate-300">Start on the free plan — upgrade only when you need more.</p>
        <a href="/register" class="btn-primary mt-7 inline-flex items-center gap-2 rounded-full bg-emerald-500 px-7 py-3.5 font-semibold text-[#05080a] hover:bg-emerald-400 transition-colors">Create your free account</a>
      </div>
    </div>
  </section>
</Base>
