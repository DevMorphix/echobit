---
import Base from '../layouts/Base.astro';

const values = [
  { title: 'Language-first', body: 'India speaks hundreds of languages. We build for them — not just English — so everyone gets accurate notes in their own tongue.' },
  { title: 'Privacy by default', body: 'Your conversations are yours. We never sell your data, and deletion is always one request away.' },
  { title: 'Effortless by design', body: 'Hit record and get on with your day. Echobit handles the transcript, summary, and minutes for you.' },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://echobits.xyz/' },
    { '@type': 'ListItem', position: 2, name: 'About', item: 'https://echobits.xyz/about' },
  ],
};
---
<Base
  title="About – Echobit"
  description="Echobit is an AI meeting recorder and transcriber built for India by Devmorphix. Learn about our mission to make every conversation accessible in your language."
  path="/about"
  jsonLd={[breadcrumb]}
>
  <section class="relative overflow-hidden max-w-3xl mx-auto px-6 pt-20 pb-12">
    <div class="pointer-events-none absolute left-1/2 top-[-6rem] -z-10 h-72 w-[36rem] -translate-x-1/2 rounded-full bg-emerald-500/20 blur-3xl animate-float-slow"></div>
    <p class="text-sm font-semibold uppercase tracking-wider text-emerald-400">About</p>
    <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight text-white leading-tight">Meetings, <span class="text-gradient">in every language.</span></h1>
    <p class="mt-6 text-lg text-slate-300 leading-relaxed">
      Echobit is an AI meeting companion built for India. We record meetings and lectures, transcribe
      them in English and 20+ Indian languages, and turn them into clear summaries, action items, and
      shareable minutes — automatically.
    </p>
    <p class="mt-4 text-slate-400 leading-relaxed">
      We started Echobit because the best note-taking tools ignored the languages most of the country
      actually speaks. People shouldn't have to switch to English just to get usable notes. So we built
      transcription that understands Hindi, Tamil, Telugu, Malayalam, and many more — with summaries you
      can read in your own language or in English.
    </p>
  </section>

  <section class="section-alt">
    <div class="max-w-5xl mx-auto px-6 py-16 reveal">
      <h2 class="text-2xl font-bold tracking-tight text-white mb-8">What we believe</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        {values.map((v) => (
          <div data-stagger class="card rounded-2xl p-6 hover:-translate-y-1">
            <h3 class="font-semibold text-white">{v.title}</h3>
            <p class="mt-2 text-sm text-slate-400 leading-relaxed">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold tracking-tight text-white">Built by Devmorphix</h2>
    <p class="mt-3 text-slate-300 leading-relaxed">
      Echobit is built and maintained by <strong class="text-white">Devmorphix</strong>, a small team
      passionate about AI-powered productivity tools that work for real, multilingual workplaces. Have
      feedback or a partnership idea? <a href="/contact" class="font-medium text-emerald-400 underline hover:text-emerald-300">We'd love to hear from you</a>.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row gap-3">
      <a href="/register" class="btn-primary rounded-full bg-emerald-500 px-7 py-3.5 text-center font-semibold text-[#05080a] hover:bg-emerald-400 transition-colors">Start for free</a>
      <a href="/features" class="rounded-full border border-white/15 bg-white/5 px-7 py-3.5 text-center font-semibold text-slate-200 backdrop-blur-sm hover:border-white/30 hover:bg-white/10 transition-colors">Explore features</a>
    </div>
  </section>
</Base>
