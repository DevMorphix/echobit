            <svg class="h-5 w-5 flex-shrink-0 text-slate-400 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
          </summary>
          <p class="pb-5 -mt-1 text-[15px] leading-relaxed text-slate-600">{f.a}</p>
