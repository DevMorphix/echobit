---
import Base from '../layouts/Base.astro';

const steps = [
  { n: '01', title: 'Record', desc: 'Capture meetings and lectures on the web or the Android app — even while it runs in the background.' },
  { n: '02', title: 'Transcribe', desc: 'Accurate speech-to-text in English and 20+ Indian languages, with speaker-friendly formatting.' },
  { n: '03', title: 'Summarise', desc: 'AI distills the conversation into key points, decisions, and clear action items.' },
  { n: '04', title: 'Share', desc: 'Export polished, branded meeting minutes as PDF — or share them in a single tap.' },
];

const features = [
  { title: 'Background recording', desc: 'Keep recording while you take notes or switch apps. Echobit runs quietly in the background on Android.', d: 'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z' },
  { title: 'Multilingual transcription', desc: 'High-accuracy transcription across English and 20+ Indian languages — handles accents and crosstalk.', d: 'M3 5h12M9 3v2m1.048 3.5A18.022 18.022 0 016.412 9m6.088 9L21 21m-3-3a18.022 18.022 0 01-3.588-9M3 21l3-3' },
  { title: 'AI summaries', desc: 'Get a concise, readable summary the moment your recording ends — no manual note-taking.', d: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z' },
  { title: 'Meeting minutes', desc: 'Auto-generate professional minutes with attendees, decisions, and next steps — PDF ready.', d: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
  { title: 'Action items', desc: 'Echobit pulls out tasks, owners, and deadlines so nothing slips after the meeting.', d: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
  { title: 'Export & templates', desc: 'Choose a template or build your own and export branded minutes your way.', d: 'M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4' },
];

const languages = ['Hindi', 'Tamil', 'Telugu', 'Bengali', 'Kannada', 'Malayalam', 'Marathi', 'Gujarati', 'Punjabi', 'Odia', 'English'];
const langRow2 = languages.slice().reverse();

const useCases = [
  { emoji: '🏢', title: 'Teams', desc: 'Never lose a decision or follow-up from standups, client calls, and reviews.' },
  { emoji: '🎓', title: 'Students', desc: 'Turn lectures into searchable transcripts and tidy study notes.' },
  { emoji: '🏥', title: 'Healthcare', desc: 'Document consultations and ward rounds — accurately, in regional languages.' },
  { emoji: '🎙️', title: 'Journalists', desc: 'Transcribe interviews and press briefings in seconds, in any language.' },
];

const testimonials = [
  { name: 'Priya Sharma', role: 'Product Manager, Bengaluru', quote: 'The action-item extraction alone saves me half an hour after every sprint meeting.', bg: 'bg-emerald-600' },
  { name: 'Arjun Nair', role: 'Medical Resident, Kochi', quote: 'I record ward rounds in Malayalam and the accuracy is genuinely impressive — even the medical terms.', bg: 'bg-teal-600' },
  { name: 'Sneha Patel', role: 'MBA Student, Ahmedabad', quote: 'Lectures become Gujarati summaries I can actually study from. Total game changer.', bg: 'bg-green-600' },
];

const freeFeatures = ['3 recordings / month', 'English + Malayalam', 'AI transcription & summary', '1 GB storage'];
const proFeatures = ['40 recordings / month', '20+ languages', 'Meeting minutes + action items', 'PDF export & templates'];

const stats: { count?: number; suffix?: string; text?: string; label: string }[] = [
  { count: 20, suffix: '+', label: 'Indian languages' },
  { count: 3, suffix: ' hrs', label: 'Max recording' },
  { text: 'Seconds', label: 'To a summary' },
  { text: 'Free', label: 'Forever plan' },
];

const faqs = [
  { q: 'Which languages does Echobit support?', a: 'English plus 20+ Indian languages, including Hindi, Tamil, Telugu, Malayalam, Bengali, Kannada, Marathi, Gujarati, Punjabi, and Odia. Summaries can be produced in English or your chosen language.' },
  { q: 'Is there a free plan?', a: 'Yes — Echobit has a free forever plan with 3 recordings per month, AI transcription, and summaries. No credit card required to start.' },
  { q: 'Can I record on my phone?', a: 'Yes. Echobit has an Android app that keeps recording in the background, plus a web app. Recordings sync to your account when Cloud Sync is on.' },
  { q: 'How accurate is the transcription?', a: 'Echobit uses state-of-the-art speech-to-text models and stays accurate even with accents, crosstalk, and background noise. Clear audio gives the best results.' },
  { q: 'How long can a recording be?', a: 'Up to 3 hours per recording, depending on your plan. Long recordings are processed automatically.' },
  { q: 'Can I export meeting minutes?', a: 'Yes — generate professional meeting minutes with attendees, decisions, and action items, and export them as PDF using built-in or custom templates.' },
  { q: 'Is my data private and secure?', a: 'Yes. Your data is encrypted in transit, never sold, and you can request full account and data deletion at any time from the app or our deletion page.' },
];

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Echobit',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Android, Web',
    description: 'AI meeting recorder and transcriber. Records meetings and lectures, transcribes in English and 20+ Indian languages, and generates summaries, action items, and meeting minutes.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'INR' },
    publisher: { '@type': 'Organization', name: 'Devmorphix' },
    featureList: [
      'AI transcription in 20+ Indian languages',
      'Automatic AI summaries',
      'Meeting minutes (PDF export)',
      'Action-item extraction',
      'Background recording on Android',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---
<Base path="/" jsonLd={pageSchema}>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-dots"></div>
      <div class="absolute left-1/2 top-[-8rem] h-[26rem] w-[42rem] -translate-x-1/2 rounded-full bg-emerald-300/30 blur-3xl animate-float-slow"></div>
      <div class="absolute right-[-6rem] top-24 h-72 w-72 rounded-full bg-teal-300/25 blur-3xl animate-float"></div>
      <div class="absolute left-[-6rem] top-44 h-72 w-72 rounded-full bg-emerald-200/30 blur-3xl animate-float-slow"></div>
    </div>
    <div class="max-w-4xl mx-auto px-6 pt-20 pb-12 text-center">
      <a href="/#features" class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-xs font-medium text-slate-600 shadow-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        AI meeting companion · now in 20+ Indian languages
      </a>
      <h1 class="mt-7 text-4xl sm:text-6xl font-bold tracking-tight text-slate-900 leading-[1.05]">
        Every meeting, captured and summarised
        <span class="text-gradient"> in your language.</span>
      </h1>
      <p class="mt-6 text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
        Stop scrambling for notes. Echobit records your meetings and lectures, transcribes them in
        English and 20+ Indian languages, and hands you a clean summary, action items, and
        ready-to-share minutes — in seconds, automatically.
      </p>
      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/register" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-full bg-emerald-600 px-7 py-3.5 font-semibold text-white shadow-sm shadow-emerald-600/20 hover:bg-emerald-500 transition-colors">
          Start for free
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
        <a href="/pricing" class="w-full sm:w-auto inline-flex items-center justify-center rounded-full border border-slate-300 px-7 py-3.5 font-semibold text-slate-700 hover:border-slate-400 hover:bg-slate-50 transition-colors">
          See pricing
        </a>
      </div>
      <p class="mt-5 text-sm text-slate-400">Free forever plan · No credit card · Android &amp; Web</p>
    </div>

    <!-- Product mock -->
    <div class="max-w-3xl mx-auto px-6 pb-20 reveal">
      <div class="rounded-2xl border border-slate-200 bg-white shadow-xl shadow-slate-900/5 overflow-hidden animate-float-slow">
        <div class="flex items-center gap-1.5 border-b border-slate-100 px-4 py-3">
          <span class="h-2.5 w-2.5 rounded-full bg-slate-200"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-slate-200"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-slate-200"></span>
          <span class="ml-3 text-xs text-slate-400">Weekly sync · 24 min · Hindi</span>
        </div>
        <div class="grid sm:grid-cols-2 gap-px bg-slate-100">
          <div class="bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-3">Transcript</p>
            <p class="text-sm text-slate-600 leading-relaxed">“आज की मीटिंग में हमने Q3 टारगेट्स पर चर्चा की। मार्केटिंग टीम अगले हफ्ते नई कैंपेन लॉन्च करेगी।”</p>
            <p class="mt-3 inline-flex items-center gap-1.5 text-xs text-emerald-600 font-medium">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
              98% confidence
            </p>
          </div>
          <div class="bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-3">Summary &amp; actions</p>
            <p class="text-sm text-slate-600 leading-relaxed">Q3 targets reviewed. Marketing to launch the new campaign next week.</p>
            <ul class="mt-3 space-y-2 text-sm text-slate-700">
              <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Finalise campaign brief — Marketing</li>
              <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Share Q3 dashboard — Priya</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-y border-slate-200 bg-slate-50">
    <div class="max-w-5xl mx-auto px-6 py-12 grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
      {stats.map((s) => (
        <div>
          <p class="text-3xl sm:text-4xl font-bold text-slate-900 tabular-nums">
            {s.count !== undefined ? (
              <><span class="stat" data-count={s.count}>0</span>{s.suffix}</>
            ) : s.text}
          </p>
          <p class="mt-1 text-sm text-slate-500">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-6xl mx-auto px-6 py-20 sm:py-28 reveal">
    <div class="max-w-2xl mb-14">
      <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">How it works</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-slate-900">From conversation to clarity in four steps</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((s) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-6 transition duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-900/5">
          <p class="text-sm font-bold text-emerald-600">{s.n}</p>
          <h3 class="mt-3 text-lg font-semibold text-slate-900">{s.title}</h3>
          <p class="mt-2 text-sm text-slate-600 leading-relaxed">{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="bg-slate-50 border-y border-slate-200">
    <div class="max-w-6xl mx-auto px-6 py-20 sm:py-28 reveal">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">Features</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-slate-900">Everything you need after the meeting ends</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((f) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 hover:shadow-md hover:shadow-slate-900/5 transition-shadow">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={f.d} /></svg>
            </div>
            <h3 class="mt-4 text-lg font-semibold text-slate-900">{f.title}</h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Languages -->
  <section id="languages" class="py-20 sm:py-28">
    <div class="max-w-6xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
      <div class="reveal">
        <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">Built for India</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-slate-900">Transcribe in your mother tongue</h2>
        <p class="mt-4 text-slate-600 leading-relaxed">
          Most tools stop at English. Echobit understands 20+ Indian languages with native-level
          accuracy — so your team can speak naturally and still get clean, English-ready summaries.
        </p>
        <a href="/features" class="mt-6 inline-flex items-center gap-2 font-semibold text-emerald-600 hover:text-emerald-700 transition-colors">
          Explore language support
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      </div>
      <div class="reveal rounded-2xl border border-slate-200 bg-white p-6 shadow-lg shadow-slate-900/5">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-50 text-emerald-600">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5h10M11 9h7M3 5l2 2 3-3" /></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-slate-900">Live transcript</p>
            <p class="text-xs text-slate-400">Tamil · just now</p>
          </div>
        </div>
        <div class="rounded-xl bg-slate-50 border border-slate-100 p-4 text-sm text-slate-700 leading-relaxed">
          “இந்த காலாண்டில் நமது விற்பனை 20% அதிகரித்துள்ளது. அடுத்த வாரம் புதிய திட்டத்தை தொடங்குவோம்.”
        </div>
        <div class="mt-4 border-t border-slate-100 pt-4">
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">English summary</p>
          <p class="text-sm text-slate-600">Sales grew 20% this quarter; the new initiative launches next week.</p>
        </div>
      </div>
    </div>

    <!-- Language marquee -->
    <div class="mt-16 overflow-hidden marquee-mask reveal">
      <div class="flex w-max gap-3 animate-marquee">
        {[...languages, ...languages].map((l) => (
          <span class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-600 shadow-sm whitespace-nowrap">{l}</span>
        ))}
      </div>
      <div class="mt-3 flex w-max gap-3 animate-marquee-rev">
        {[...langRow2, ...langRow2].map((l) => (
          <span class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-600 shadow-sm whitespace-nowrap">{l}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="bg-slate-50 border-y border-slate-200">
    <div class="max-w-6xl mx-auto px-6 py-20 sm:py-28 reveal">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">Who it's for</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-slate-900">Built for every kind of conversation</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {useCases.map((u) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 transition duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-900/5">
            <div class="text-3xl">{u.emoji}</div>
            <h3 class="mt-4 text-lg font-semibold text-slate-900">{u.title}</h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing teaser -->
  <section class="max-w-5xl mx-auto px-6 py-20 sm:py-28 reveal">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">Pricing</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-slate-900">Start free. Upgrade when you grow.</h2>
    </div>
    <div class="grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
      <div class="rounded-2xl border border-slate-200 bg-white p-7 flex flex-col">
        <h3 class="text-lg font-semibold text-slate-900">Free</h3>
        <p class="mt-1 text-sm text-slate-500">For getting started</p>
        <p class="mt-4 text-4xl font-bold text-slate-900">₹0<span class="text-base font-normal text-slate-400">/mo</span></p>
        <ul class="mt-6 space-y-2.5 flex-1">
          {freeFeatures.map((f) => (
            <li class="flex items-center gap-2.5 text-sm text-slate-600">
              <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
              {f}
            </li>
          ))}
        </ul>
        <a href="/register" class="mt-7 block rounded-xl border border-slate-300 py-3 text-center text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors">Get started</a>
      </div>
      <div class="rounded-2xl border-2 border-emerald-500 bg-white p-7 flex flex-col relative">
        <span class="absolute -top-3 left-7 rounded-full bg-emerald-600 px-3 py-1 text-xs font-bold text-white">Most popular</span>
        <h3 class="text-lg font-semibold text-slate-900">Pro</h3>
        <p class="mt-1 text-sm text-slate-500">For power users</p>
        <p class="mt-4 text-4xl font-bold text-slate-900">₹499<span class="text-base font-normal text-slate-400">/mo</span></p>
        <ul class="mt-6 space-y-2.5 flex-1">
          {proFeatures.map((f) => (
            <li class="flex items-center gap-2.5 text-sm text-slate-700">
              <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
              {f}
            </li>
          ))}
        </ul>
        <a href="/pricing" class="mt-7 block rounded-xl bg-emerald-600 py-3 text-center text-sm font-semibold text-white shadow-sm shadow-emerald-600/20 hover:bg-emerald-500 transition-colors">See all plans</a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-slate-50 border-y border-slate-200">
    <div class="max-w-6xl mx-auto px-6 py-20 sm:py-28 reveal">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">Loved by busy people</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-slate-900">What our users say</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <figure class="rounded-2xl border border-slate-200 bg-white p-6 flex flex-col">
            <div class="flex gap-0.5 text-amber-400 mb-3">
              {[1,2,3,4,5].map(() => (
                <svg class="h-4 w-4 fill-current" viewBox="0 0 20 20"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.07 3.29a1 1 0 00.95.69h3.46c.97 0 1.37 1.24.59 1.81l-2.8 2.03a1 1 0 00-.36 1.12l1.07 3.29c.3.92-.76 1.69-1.54 1.12l-2.8-2.03a1 1 0 00-1.18 0l-2.8 2.03c-.78.57-1.83-.2-1.54-1.12l1.07-3.29a1 1 0 00-.36-1.12L2.07 8.72c-.78-.57-.38-1.81.59-1.81h3.46a1 1 0 00.95-.69L9.05 2.93z"/></svg>
              ))}
            </div>
            <blockquote class="text-sm text-slate-600 leading-relaxed flex-1">“{t.quote}”</blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-slate-100 pt-4">
              <span class={`flex h-9 w-9 items-center justify-center rounded-full text-sm font-bold text-white ${t.bg}`}>{t.name[0]}</span>
              <span>
                <span class="block text-sm font-medium text-slate-900">{t.name}</span>
                <span class="block text-xs text-slate-400">{t.role}</span>
              </span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="max-w-3xl mx-auto px-6 py-20 sm:py-28 reveal">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">FAQ</p>
