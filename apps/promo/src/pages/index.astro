---
import Base from '../layouts/Base.astro';
import { DEFAULT_PRICES, DEFAULT_FEATURES } from '@echobit/shared/plans';

const steps = [
  { n: '01', title: 'Record', desc: 'Capture meetings and lectures on the web or the Android app — even while it runs in the background.' },
  { n: '02', title: 'Transcribe', desc: 'Accurate speech-to-text in English and 20+ Indian languages, with speaker-friendly formatting.' },
  { n: '03', title: 'Summarise', desc: 'AI distills the conversation into key points, decisions, and clear action items.' },
  { n: '04', title: 'Share', desc: 'Export polished, branded meeting minutes as PDF — or share them in a single tap.' },
];

// Each language shown in its own script (endonym), with the English name as a
// small label so the marquee reads for everyone.
const languages = [
  { native: 'हिन्दी',    en: 'Hindi' },
  { native: 'தமிழ்',     en: 'Tamil' },
  { native: 'తెలుగు',    en: 'Telugu' },
  { native: 'বাংলা',     en: 'Bengali' },
  { native: 'ಕನ್ನಡ',     en: 'Kannada' },
  { native: 'മലയാളം',   en: 'Malayalam' },
  { native: 'मराठी',     en: 'Marathi' },
  { native: 'ગુજરાતી',   en: 'Gujarati' },
  { native: 'ਪੰਜਾਬੀ',    en: 'Punjabi' },
  { native: 'ଓଡ଼ିଆ',     en: 'Odia' },
  { native: 'English',   en: 'English' },
];
const langRow2 = languages.slice().reverse();

const useCases = [
  { emoji: '🏢', title: 'Teams', desc: 'Never lose a decision or follow-up from standups, client calls, and reviews.' },
  { emoji: '🎓', title: 'Students', desc: 'Turn lectures into searchable transcripts and tidy study notes.' },
  { emoji: '🏥', title: 'Healthcare', desc: 'Document consultations and ward rounds — accurately, in regional languages.' },
  { emoji: '🎙️', title: 'Journalists', desc: 'Transcribe interviews and press briefings in seconds, in any language.' },
];

// Real-feeling mix — not every review is a glowing 5★.
const testimonials = [
  { name: 'Priya Sharma', role: 'Product Manager, Bengaluru', rating: 5, quote: 'The action-item extraction alone saves me half an hour after every sprint meeting.', bg: 'bg-emerald-600' },
  { name: 'Arjun Nair', role: 'Medical Resident, Kochi', rating: 5, quote: 'I record ward rounds in Malayalam and the accuracy is genuinely impressive — even the medical terms.', bg: 'bg-teal-600' },
  { name: 'Sneha Patel', role: 'MBA Student, Ahmedabad', rating: 4, quote: 'Lectures become Gujarati summaries I can actually study from. It trips up a little on heavy crosstalk, but still a huge help.', bg: 'bg-green-600' },
  { name: 'Rahul Verma', role: 'Founder, Pune', rating: 3, quote: 'Transcription and summaries are solid. My main gripe is processing speed on long recordings — I hope that gets faster.', bg: 'bg-emerald-700' },
  { name: 'Fatima Sheikh', role: 'Journalist, Hyderabad', rating: 4, quote: 'Interview transcripts in Telugu and Urdu save me hours. Export options could be richer, but the core is reliable.', bg: 'bg-teal-700' },
  { name: 'Karan Mehta', role: 'Sales Lead, Mumbai', rating: 5, quote: 'Every client call ends with clean minutes I can share in one tap. It is just part of my workflow now.', bg: 'bg-green-700' },
];

// Pricing teaser stays in sync with the app/web (shared plan source of truth).
const freeFeatures = DEFAULT_FEATURES.free.filter((f) => f.included).map((f) => f.text).slice(0, 4);
const proFeatures = DEFAULT_FEATURES.pro.filter((f) => f.included).map((f) => f.text).slice(0, 4);
const toNum = (s: string) => parseInt(s.replace(/[^\d]/g, ''), 10) || 0;
const proSave = Math.round((1 - toNum(DEFAULT_PRICES.pro.annualMonthly) / toNum(DEFAULT_PRICES.pro.monthlyPrice)) * 100);

const stats: { count?: number; suffix?: string; text?: string; label: string }[] = [
  { count: 20, suffix: '+', label: 'Indian languages' },
  { count: 98, suffix: '%', label: 'Transcription accuracy' },
  { count: 10, suffix: '×', label: 'Faster than typing notes' },
  { count: 30, suffix: ' min', label: 'Saved per meeting' },
];

const faqs = [
  { q: 'Which languages does Echobit support?', a: 'English plus 20+ Indian languages, including Hindi, Tamil, Telugu, Malayalam, Bengali, Kannada, Marathi, Gujarati, Punjabi, and Odia. Summaries can be produced in English or your chosen language.' },
  { q: 'Is there a free plan?', a: 'Yes — Echobit has a free forever plan with 3 recordings per month, AI transcription, and summaries. No credit card required to start.' },
  { q: 'Can I record on my phone?', a: 'Yes. Echobit has an Android app that keeps recording in the background, plus a web app. Recordings sync to your account when Cloud Sync is on.' },
  { q: 'How accurate is the transcription?', a: 'Echobit uses state-of-the-art speech-to-text models and stays accurate even with accents, crosstalk, and background noise. Clear audio gives the best results.' },
  { q: 'Is my data private and secure?', a: 'Yes. Your data is encrypted in transit, never sold, and you can request full account and data deletion at any time from the app or our deletion page.' },
];

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Echobit',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Android, Web',
    description: 'AI meeting recorder and transcriber. Records meetings and lectures, transcribes in English and 20+ Indian languages, and generates summaries, action items, and meeting minutes.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'INR' },
    publisher: { '@type': 'Organization', name: 'Devmorphix' },
    featureList: [
      'AI transcription in 20+ Indian languages',
      'Automatic AI summaries',
      'Meeting minutes (PDF export)',
      'Action-item extraction',
      'Background recording on Android',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---
<Base path="/" jsonLd={pageSchema}>
  <!-- Hero -->
  <section class="relative isolate overflow-hidden">
    <div class="hero-glow" aria-hidden="true"></div>
    <div id="dot-field" class="dot-field" aria-hidden="true"></div>
    <div class="max-w-5xl mx-auto px-6 pt-28 sm:pt-32 pb-12 text-center">
      <a href="/features" class="group inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3.5 py-1.5 text-xs font-medium text-slate-300 backdrop-blur-sm transition-colors hover:border-emerald-400/40 hover:text-white">
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
        </span>
        AI meeting companion · now in 20+ Indian languages
      </a>
      <h1 class="mt-10 text-4xl sm:text-6xl font-bold tracking-tight text-white leading-[1.05] text-balance">
        Every meeting, captured and <br class="hidden sm:block" />summarised<span class="text-gradient"> in your language.</span>
      </h1>
      <p class="mt-8 text-lg text-slate-300 max-w-2xl mx-auto leading-relaxed">
        Echobit records your meetings and lectures, transcribes them in English and 20+ Indian
        languages, and hands you a clean summary, action items, and shareable minutes — in seconds.
      </p>
      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/register" class="btn-primary w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-full bg-emerald-500 px-7 py-3.5 font-semibold text-[#05080a] hover:bg-emerald-400 transition-colors">
          Start for free
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
        <a href="/pricing" class="w-full sm:w-auto inline-flex items-center justify-center rounded-full border border-white/15 bg-white/5 px-7 py-3.5 font-semibold text-slate-200 backdrop-blur-sm hover:border-white/30 hover:bg-white/10 transition-colors">
          See pricing
        </a>
      </div>
      <p class="mt-5 text-sm text-slate-500">Free forever plan · No credit card · Android &amp; Web</p>
    </div>

    <!-- Product mock -->
    <div class="max-w-3xl mx-auto px-6 pb-20 reveal">
      <div class="card rounded-2xl overflow-hidden animate-float-slow">
        <div class="flex items-center gap-1.5 border-b border-white/10 px-4 py-3">
          <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
          <span class="ml-2 inline-flex items-center gap-1.5 rounded-full bg-rose-500/15 px-2 py-0.5 text-[11px] font-semibold text-rose-300">
            <span class="rec-dot"></span> REC
          </span>
          <span class="eq ml-1" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span>
          <span class="ml-auto text-xs text-slate-400">Weekly sync · 24 min · Hindi</span>
        </div>
        <div class="grid sm:grid-cols-2 gap-px bg-white/5">
          <div class="bg-white/[0.02] p-5">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-3">Transcript</p>
            <p class="text-sm text-slate-300 leading-relaxed">“आज की मीटिंग में हमने Q3 टारगेट्स पर चर्चा की। मार्केटिंग टीम अगले हफ्ते नई कैंपेन लॉन्च करेगी।”</p>
            <p class="mt-3 inline-flex items-center gap-1.5 text-xs text-emerald-400 font-medium">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
              98% confidence
            </p>
          </div>
          <div class="bg-white/[0.02] p-5">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-3">Summary &amp; actions</p>
            <p class="text-sm text-slate-300 leading-relaxed">Q3 targets reviewed. Marketing to launch the new campaign next week.</p>
            <ul class="mt-3 space-y-2 text-sm text-slate-200">
              <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-400"></span> Finalise campaign brief — Marketing</li>
              <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-400"></span> Share Q3 dashboard — Priya</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section-alt">
    <div class="max-w-5xl mx-auto px-6 py-12 grid grid-cols-2 sm:grid-cols-4 gap-8 text-center reveal">
      {stats.map((s) => (
        <div data-stagger>
          <p class="text-3xl sm:text-4xl font-bold text-white tabular-nums">
            {s.count !== undefined ? (
              <><span class="stat text-gradient" data-count={s.count}>0</span>{s.suffix}</>
            ) : <span class="text-gradient">{s.text}</span>}
          </p>
          <p class="mt-1 text-sm text-slate-400">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-6xl mx-auto px-6 py-20 sm:py-28 reveal">
    <div class="max-w-2xl mb-14">
      <p class="text-sm font-semibold uppercase tracking-wider text-emerald-400">How it works</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-white">From conversation to clarity in four steps</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((s) => (
        <div data-stagger class="card rounded-2xl p-6 hover:-translate-y-1">
          <p class="text-sm font-bold text-emerald-400">{s.n}</p>
          <h3 class="mt-3 text-lg font-semibold text-white">{s.title}</h3>
          <p class="mt-2 text-sm text-slate-400 leading-relaxed">{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Languages -->
  <section id="languages" class="py-20 sm:py-28">
    <div class="max-w-6xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
      <div class="reveal">
        <p class="text-sm font-semibold uppercase tracking-wider text-emerald-400">Built for India</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-white">Transcribe in your mother tongue</h2>
        <p class="mt-4 text-slate-300 leading-relaxed">
          Most tools stop at English. Echobit understands 20+ Indian languages with native-level
          accuracy — so your team can speak naturally and still get clean, English-ready summaries.
        </p>
        <a href="/features" class="group mt-6 inline-flex items-center gap-2 font-semibold text-emerald-400 hover:text-emerald-300 transition-colors">
          Explore language support
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      </div>
      <div class="reveal card rounded-2xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-400 ring-1 ring-inset ring-emerald-400/20">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5h10M11 9h7M3 5l2 2 3-3" /></svg>
          </div>
          <div class="flex-1">
            <p class="text-sm font-semibold text-white">Live transcript</p>
            <p class="text-xs text-slate-400">Tamil · just now</p>
          </div>
          <span class="eq" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span>
        </div>
        <div class="rounded-xl bg-white/[0.03] border border-white/10 p-4 text-sm text-slate-200 leading-relaxed">
          “இந்த காலாண்டில் நமது விற்பனை 20% அதிகரித்துள்ளது. அடுத்த வாரம் புதிய திட்டத்தை தொடங்குவோம்.”
        </div>
        <div class="mt-4 border-t border-white/10 pt-4">
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">English summary</p>
          <p class="text-sm text-slate-300">Sales grew 20% this quarter; the new initiative launches next week.</p>
        </div>
      </div>
    </div>

    <!-- Language marquee -->
    <div class="mt-16 overflow-hidden marquee-mask reveal">
      <div class="flex w-max animate-marquee">
        {[...languages, ...languages].map((l) => (
          <span class="mr-3 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 backdrop-blur-sm whitespace-nowrap">
            <span class="text-base font-semibold text-slate-100">{l.native}</span>
            {l.en !== l.native && <span class="text-xs font-medium text-slate-500">{l.en}</span>}
          </span>
        ))}
      </div>
      <div class="mt-3 flex w-max animate-marquee-rev">
        {[...langRow2, ...langRow2].map((l) => (
          <span class="mr-3 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 backdrop-blur-sm whitespace-nowrap">
            <span class="text-base font-semibold text-slate-100">{l.native}</span>
            {l.en !== l.native && <span class="text-xs font-medium text-slate-500">{l.en}</span>}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="section-alt">
    <div class="max-w-6xl mx-auto px-6 py-20 sm:py-28 reveal">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-emerald-400">Who it's for</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-white">Built for every kind of conversation</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {useCases.map((u) => (
          <div data-stagger class="card rounded-2xl p-6 hover:-translate-y-1">
            <div class="text-3xl">{u.emoji}</div>
            <h3 class="mt-4 text-lg font-semibold text-white">{u.title}</h3>
            <p class="mt-2 text-sm text-slate-400 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing teaser -->
  <section class="max-w-5xl mx-auto px-6 py-20 sm:py-28 reveal">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <p class="text-sm font-semibold uppercase tracking-wider text-emerald-400">Pricing</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-white">Start free. Upgrade when you grow.</h2>
      <p class="mt-4 text-slate-400">No credit card to start. Pay monthly or save up to {proSave}% on annual billing.</p>
    </div>
    <div class="grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto items-stretch">
      <!-- Free -->
      <div class="card rounded-2xl p-7 flex flex-col">
        <h3 class="text-lg font-semibold text-white">Free</h3>
        <p class="mt-1 text-sm text-slate-400">For getting started</p>
        <p class="mt-5 flex items-baseline gap-1.5">
          <span class="text-4xl font-bold text-white">{DEFAULT_PRICES.free.monthlyPrice}</span>
          <span class="text-sm text-slate-400">/mo</span>
        </p>
        <p class="mt-1.5 text-xs text-slate-500">Free forever · no card needed</p>
        <ul class="mt-6 space-y-3 flex-1 border-t border-white/10 pt-6">
          {freeFeatures.map((f) => (
            <li class="flex items-start gap-2.5 text-sm text-slate-300">
              <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
              {f}
            </li>
          ))}
        </ul>
        <a href="/register" class="mt-7 block rounded-xl border border-white/15 bg-white/5 py-3 text-center text-sm font-semibold text-slate-200 hover:bg-white/10 transition-colors">Get started free</a>
      </div>
      <!-- Pro -->
      <div class="card-featured rounded-2xl p-7 flex flex-col relative">
        <span class="absolute -top-3 left-7 rounded-full bg-emerald-500 px-3 py-1 text-xs font-bold text-[#05080a]">Most popular</span>
        <div class="flex items-center justify-between gap-2">
          <h3 class="text-lg font-semibold text-white">Pro</h3>
          <span class="rounded-full bg-emerald-500/15 px-2.5 py-1 text-xs font-semibold text-emerald-300 ring-1 ring-inset ring-emerald-400/30">Save {proSave}%</span>
        </div>
        <p class="mt-1 text-sm text-slate-400">For power users</p>
        <p class="mt-5 flex items-baseline gap-1.5">
          <span class="text-4xl font-bold text-white">{DEFAULT_PRICES.pro.monthlyPrice}</span>
          <span class="text-sm text-slate-400">/mo</span>
        </p>
        <p class="mt-1.5 text-xs text-emerald-300">or {DEFAULT_PRICES.pro.annualMonthly}/mo billed yearly</p>
        <ul class="mt-6 space-y-3 flex-1 border-t border-white/10 pt-6">
          {proFeatures.map((f) => (
            <li class="flex items-start gap-2.5 text-sm text-slate-200">
              <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
              {f}
            </li>
          ))}
        </ul>
        <a href="/register" class="btn-primary mt-7 block rounded-xl bg-emerald-500 py-3 text-center text-sm font-semibold text-[#05080a] hover:bg-emerald-400 transition-colors">Get Pro</a>
      </div>
    </div>
    <p class="mt-8 text-center text-sm text-slate-400">
      Need more recordings or a team plan? <a href="/pricing" class="font-medium text-emerald-400 underline hover:text-emerald-300">Compare all four plans →</a>
    </p>
  </section>

  <!-- Testimonials carousel — 3 visible, 6 rotating -->
  <section class="section-alt">
    <div class="max-w-6xl mx-auto px-6 py-20 sm:py-28">
      <div class="flex items-end justify-between gap-4 mb-12 reveal">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-wider text-emerald-400">Loved by busy people</p>
          <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-white">What our users say</h2>
        </div>
        <div class="hidden sm:flex gap-2 flex-shrink-0">
          <button id="t-prev" type="button" aria-label="Previous testimonials" class="flex h-10 w-10 items-center justify-center rounded-full border border-white/15 bg-white/5 text-slate-300 transition-colors hover:border-emerald-400/40 hover:bg-white/10 hover:text-white">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          </button>
          <button id="t-next" type="button" aria-label="Next testimonials" class="flex h-10 w-10 items-center justify-center rounded-full border border-white/15 bg-white/5 text-slate-300 transition-colors hover:border-emerald-400/40 hover:bg-white/10 hover:text-white">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </button>
        </div>
      </div>
      <div id="t-carousel" class="t-carousel">
        <div id="t-track" class="t-track">
          {testimonials.map((t) => (
            <figure class="t-card card rounded-2xl p-6 flex flex-col">
              <div class="flex gap-0.5 mb-3">
                {[1,2,3,4,5].map((n) => (
                  <svg class={`h-4 w-4 fill-current ${n <= t.rating ? 'text-amber-400' : 'text-slate-700'}`} viewBox="0 0 20 20"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.07 3.29a1 1 0 00.95.69h3.46c.97 0 1.37 1.24.59 1.81l-2.8 2.03a1 1 0 00-.36 1.12l1.07 3.29c.3.92-.76 1.69-1.54 1.12l-2.8-2.03a1 1 0 00-1.18 0l-2.8 2.03c-.78.57-1.83-.2-1.54-1.12l1.07-3.29a1 1 0 00-.36-1.12L2.07 8.72c-.78-.57-.38-1.81.59-1.81h3.46a1 1 0 00.95-.69L9.05 2.93z"/></svg>
                ))}
              </div>
              <blockquote class="text-sm text-slate-300 leading-relaxed flex-1">“{t.quote}”</blockquote>
              <figcaption class="mt-5 flex items-center gap-3 border-t border-white/10 pt-4">
                <span class={`flex h-9 w-9 items-center justify-center rounded-full text-sm font-bold text-white ${t.bg}`}>{t.name[0]}</span>
                <span>
                  <span class="block text-sm font-medium text-white">{t.name}</span>
                  <span class="block text-xs text-slate-400">{t.role}</span>
                </span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="max-w-3xl mx-auto px-6 py-20 sm:py-28 reveal">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold uppercase tracking-wider text-emerald-400">FAQ</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-white">Frequently asked questions</h2>
    </div>
    <div class="divide-y divide-white/10 rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur-sm">
      {faqs.map((f) => (
        <details class="group px-6">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-left font-medium text-white transition-colors hover:text-emerald-300 [&::-webkit-details-marker]:hidden">
            {f.q}
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-400 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
          </summary>
          <p class="pb-5 -mt-1 text-[15px] leading-relaxed text-slate-400">{f.a}</p>
        </details>
      ))}
    </div>
    <p class="mt-8 text-center text-sm text-slate-400">
      Still have a question? <a href="/contact" class="font-medium text-emerald-400 underline hover:text-emerald-300">Get in touch →</a>
    </p>
  </section>

  <!-- Final CTA -->
  <section class="max-w-6xl mx-auto px-6 py-20 sm:py-28">
    <div class="relative overflow-hidden rounded-3xl border border-emerald-400/20 bg-gradient-to-br from-emerald-500/10 via-white/[0.02] to-teal-500/10 px-8 py-16 text-center">
      <div class="pointer-events-none absolute inset-0 -z-0">
        <div class="absolute -right-24 -top-24 h-64 w-64 rounded-full bg-emerald-500/30 blur-3xl animate-float"></div>
        <div class="absolute -bottom-24 -left-24 h-64 w-64 rounded-full bg-teal-500/25 blur-3xl animate-float-slow"></div>
      </div>
      <div class="relative">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white">Start your first recording today</h2>
        <p class="mt-4 text-slate-300 max-w-md mx-auto">No setup, no credit card. Record, and let Echobit handle the notes.</p>
        <a href="/register" class="btn-primary mt-8 inline-flex items-center gap-2 rounded-full bg-emerald-500 px-7 py-3.5 font-semibold text-[#05080a] hover:bg-emerald-400 transition-colors">
          Create your free account
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      </div>
    </div>
  </section>

  <script>
    import { initDotField } from '../scripts/dot-field';

    // ReactBits "Dot Field" behind the hero, in Echobit's emerald palette.
    const dotFieldEl = document.getElementById('dot-field');
    if (dotFieldEl) {
      initDotField(dotFieldEl, {
        gradientFrom: 'rgba(16, 185, 129, 0.38)',
        gradientTo: 'rgba(45, 212, 191, 0.24)',
        glowColor: 'rgba(52, 211, 153, 0.18)',
        dotSpacing: 17,
        dotRadius: 1.5,
      });
    }

    // Testimonials carousel — 3 visible (responsive), 6 rotating, seamless loop.
    const tTrack = document.getElementById('t-track');
    const tCarousel = document.getElementById('t-carousel');
    if (tTrack && tCarousel) {
      const GAP = 24; // matches .t-track gap (1.5rem)
      const total = tTrack.children.length; // 6 originals
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      // Clone the first three so the forward loop is seamless.
      Array.from(tTrack.children).slice(0, 3).forEach((c) => tTrack.appendChild(c.cloneNode(true)));
      let index = 0;
      let timer = 0;
      const stepPx = () => (tTrack.children[0] as HTMLElement).getBoundingClientRect().width + GAP;
      const apply = (animate: boolean) => {
        tTrack.style.transition = animate ? 'transform .6s cubic-bezier(.22,1,.36,1)' : 'none';
        tTrack.style.transform = `translateX(${-index * stepPx()}px)`;
      };
      const next = () => {
        index++;
        apply(true);
        if (index >= total) window.setTimeout(() => { index = 0; apply(false); }, 620);
      };
      const prev = () => {
        if (index <= 0) { index = total; apply(false); void tTrack.offsetWidth; }
        index--;
        apply(true);
      };
      const stop = () => window.clearInterval(timer);
      const start = () => { stop(); if (!reduce) timer = window.setInterval(next, 4500); };
      document.getElementById('t-next')?.addEventListener('click', () => { next(); start(); });
      document.getElementById('t-prev')?.addEventListener('click', () => { prev(); start(); });
      tCarousel.addEventListener('mouseenter', stop);
      tCarousel.addEventListener('mouseleave', start);
      window.addEventListener('resize', () => apply(false));
      apply(false);
      start();
    }

    // Count-up animation for the stats (runs once when scrolled into view).
    const nums = document.querySelectorAll<HTMLElement>('.stat');
    const run = (el: HTMLElement) => {
      const target = Number(el.dataset.count || '0');
      const dur = 1200;
      const start = performance.now();
      const tick = (now: number) => {
        const p = Math.min((now - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = String(Math.round(target * eased));
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };
    if ('IntersectionObserver' in window && nums.length) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { run(e.target as HTMLElement); io.unobserve(e.target); }
        }
      }, { threshold: 0.6 });
      nums.forEach((n) => io.observe(n));
    } else {
      nums.forEach((n) => (n.textContent = n.dataset.count || '0'));
    }
  </script>
</Base>
