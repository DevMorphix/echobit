# Copy to .env (gitignored) and fill in. Used by docker-compose.yml.

# Shared bearer secret the Worker sends on every bot request. MUST equal the
# Worker's MEET_BOT_SECRET (set there with `wrangler secret put MEET_BOT_SECRET`).
# Generate: openssl rand -hex 32
MEET_BOT_SECRET=

# Max concurrent meetings this VM accepts. Budget ~1 vCPU + ~1.2 GB RAM each.
MAX_SESSIONS=6

# Cloudflare Tunnel token: Zero Trust dashboard → Networks → Tunnels → (your
# tunnel) → install/token. The tunnel's public hostname routes to http://meetbot:8080.
TUNNEL_TOKEN=
